# =============================================================================
# Пример файла .env для Docker Compose
# =============================================================================
# Скопируйте этот файл в .env и измените параметры при необходимости
# =============================================================================

# Параметры PostgreSQL
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_password
POSTGRES_DB=audit_test

# Часовая зона
TZ=Europe/Moscow
PGTZ=Europe/Moscow

# Порт (по умолчанию 5433, чтобы не конфликтовать с продакшеном)
POSTGRES_PORT=5433

# Параметры производительности (опционально)
POSTGRES_MAX_CONNECTIONS=50
POSTGRES_SHARED_BUFFERS=64MB
POSTGRES_EFFECTIVE_CACHE_SIZE=128MB
