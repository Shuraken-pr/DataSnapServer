# =============================================================================
# Gitignore для интеграционных тестов
# =============================================================================

# Компилированные файлы
*.dcu
*.exe
*.dll
*.bpl
*.ocx

# Файлы проекта Delphi
*.dproj.local
*.dsk
*.identcache
*.tvsconfig
*.stat

# Выходные папки
Win32/
Win64/
Android/
iOS/
iOSDevice64/
Linux64/
OSX/
OSX64/

# Результаты тестов
*-results.xml
*.log

# Временные файлы
__history/
__recovery/
*.~*

# Тестовые данные (опционально)
# TestData/*.jpg
# TestData/*.png

# Docker
.docker/

# IDE
*.local
*.dof
*.cfg
